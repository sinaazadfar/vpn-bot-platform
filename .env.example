APP_ENV=development
LOG_LEVEL=INFO

POSTGRES_USER=vpn_platform
POSTGRES_PASSWORD=change_me
POSTGRES_DB=vpn_platform
DATABASE_URL=postgresql+asyncpg://vpn_platform:change_me@postgres:5432/vpn_platform

FERNET_KEY=change_me_generate_with_script

MASTER_BOT_TOKEN=
SUPER_USER_TELEGRAM_ID=

SELLER_RUNTIME_IMAGE=vpn-bot-platform-seller:latest
SELLER_DOCKER_NETWORK=vpn-bot-platform_default
SELLER_CONTAINER_LABEL_PREFIX=vpn-bot-platform
AUTO_START_SELLER_ON_CREATE=true

MARZBAN_TOKEN_PATH=/api/admin/token
API_TIMEOUT_SECONDS=20

TELEGRAM_API_IP=149.154.167.220

CARD_TO_CARD_INSTRUCTIONS=Send payment receipt to reseller support for approval.
MARZBAN_DEFAULT_PROXIES_JSON={"vless": {}}
TRIAL_ENABLED=true
TRIAL_DURATION_DAYS=1
TRIAL_DATA_LIMIT_GB=1
